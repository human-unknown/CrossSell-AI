# CrossSell AI — 环境变量
# 复制此文件为 .env 并填入实际值

# ---- 应用 ----
APP_NAME=CrossSell AI
APP_VERSION=0.1.0
DEBUG=true

# ---- 数据库 (SQLite 路径) ----
DATABASE_URL=sqlite+aiosqlite:///./crosssell.db

# ---- Model Router API (阿里云百炼) ----
# 踩点期间使用阿里云百炼免费额度
# 初赛通过后赛方发放 25,000 Credits
MODEL_ROUTER_BASE_URL=https://model-router.edu-aliyun.com/v1
MODEL_ROUTER_API_KEY=your-api-key-here

# ---- 模型选择（可按需调整） ----
TEXT_MODEL=qwen/qwen3.7-max
FAST_TEXT_MODEL=qwen/qwen3.5-flash
REASONING_MODEL=deepseek-r1
TTS_MODEL=qwen/qwen3-tts-instruct-flash
IMAGE_MODEL=qwen/wan2.7-image-pro
VIDEO_MODEL=qwen/wan2.7-t2v
VISION_MODEL=qwen/qwen3-vl-plus

# ---- 重试 ----
MAX_RETRIES=3
RETRY_DELAY=1.0
REQUEST_TIMEOUT=120

# ---- CORS (逗号分隔) ----
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000
