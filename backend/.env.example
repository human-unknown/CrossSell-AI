# CrossSell AI — 环境变量
# 复制此文件为 .env 并填入实际值

# ---- 应用 ----
APP_NAME=CrossSell AI
APP_VERSION=0.1.0
DEBUG=true

# ---- 数据库 (SQLite 路径) ----
DATABASE_URL=sqlite+aiosqlite:///./crosssell.db

# ---- Model Router API (阿里云百炼) ----
# 踩点期间使用阿里云百炼免费额度
# 初赛通过后赛方发放专属 Model Router Key
# 阿里云百炼国内: https://dashscope.aliyuncs.com/compatible-mode/v1
# CSDN Model Router: https://model-router.edu-aliyun.com/v1 (赛方Key生效后切换)
MODEL_ROUTER_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL_ROUTER_API_KEY=your-api-key-here

# ---- 模型选择 (阿里云百炼 compatible-mode 原生ID, 不含 qwen/ 前缀) ----
# 赛方 Model Router Key 生效后改回 qwen/qwen3.7-max 等格式
TEXT_MODEL=qwen-max
FAST_TEXT_MODEL=qwen-turbo
REASONING_MODEL=deepseek-r1
TTS_MODEL=cosyvoice-v1
IMAGE_MODEL=wanx2.1-t2i-turbo
VIDEO_MODEL=wan2.1-t2v-turbo
VISION_MODEL=qwen-vl-plus

# ---- 重试 ----
MAX_RETRIES=3
RETRY_DELAY=1.0
REQUEST_TIMEOUT=120

# ---- CORS (逗号分隔) ----
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000
